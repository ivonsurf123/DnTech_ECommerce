@using DnTech_ECommerce.ViewModels
@model AdminUserDetailsViewModel
@{
    ViewData["Title"] = $"Usuario: {Model.FullName}";
    Layout = "_AdminLayout";
}

<!-- Encabezado -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">@Model.FullName</h4>
        <small class="text-muted">
            <i class="bi bi-calendar"></i> Registrado el @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </small>
    </div>
    <div>
        <a asp-action="Users" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Columna Izquierda -->
    <div class="col-12 col-lg-8">
        <!-- Información del Usuario -->
        <div class="stat-card mb-3">
            <h5 class="mb-3">
                <i class="bi bi-person-circle me-2"></i>Información Personal
            </h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="text-muted mb-1">Nombre Completo</label>
                    <div><strong>@Model.FullName</strong></div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-muted mb-1">Email</label>
                    <div><strong>@Model.Email</strong></div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-muted mb-1">Teléfono</label>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <strong>@Model.PhoneNumber</strong>
                        }
                        else
                        {
                            <span class="text-muted">No especificado</span>
                        }
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-muted mb-1">Ciudad</label>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.City))
                        {
                            <strong>@Model.City</strong>
                        }
                        else
                        {
                            <span class="text-muted">No especificado</span>
                        }
                    </div>
                </div>
                <div class="col-12 mb-3">
                    <label class="text-muted mb-1">Dirección</label>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            <strong>@Model.Address</strong>
                            @if (!string.IsNullOrEmpty(Model.PostalCode))
                            {
                                <span>, @Model.PostalCode</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.Country))
                            {
                                <span>, @Model.Country</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No especificado</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="text-muted mb-1">ID de Usuario</label>
                    <div><code>@Model.Id</code></div>
                </div>
            </div>
        </div>

        <!-- Estadísticas de Pedidos -->
        <div class="stat-card mb-3">
            <h5 class="mb-3">
                <i class="bi bi-bar-chart me-2"></i>Estadísticas de Compras
            </h5>
            <div class="row text-center">
                <div class="col-6 col-md-3 mb-3">
                    <div class="stat-value text-primary">@Model.TotalOrders</div>
                    <div class="stat-label">Total Pedidos</div>
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <div class="stat-value text-success">@Model.TotalSpent.ToString("C")</div>
                    <div class="stat-label">Total Gastado</div>
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <div class="stat-value text-warning">@Model.PendingOrders</div>
                    <div class="stat-label">Pendientes</div>
                </div>
                <div class="col-6 col-md-3 mb-3">
                    <div class="stat-value text-info">@Model.CompletedOrders</div>
                    <div class="stat-label">Completados</div>
                </div>
            </div>
        </div>

        <!-- Historial de Pedidos -->
        <div class="admin-table">
            <div class="p-3 border-bottom">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-2"></i>
                    Pedidos Recientes (últimos 10)
                </h5>
            </div>

            @if (Model.RecentOrders.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><strong>@order.OrderNumber</strong></td>
                                    <td>
                                        <div>@order.OrderDate.ToString("dd/MM/yyyy")</div>
                                        <small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                                    </td>
                                    <td><strong>@order.TotalAmount.ToString("C")</strong></td>
                                    <td>
                                        @switch (order.Status)
                                        {
                                            case "Pending":
                                                <span class="badge bg-warning text-dark">Pendiente</span>
                                                break;
                                            case "Processing":
                                                <span class="badge bg-info">Procesando</span>
                                                break;
                                            case "Shipped":
                                                <span class="badge bg-primary">Enviado</span>
                                                break;
                                            case "Delivered":
                                                <span class="badge bg-success">Entregado</span>
                                                break;
                                            case "Cancelled":
                                                <span class="badge bg-danger">Cancelado</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="OrderDetails" asp-route-id="@order.OrderId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-inbox display-4"></i>
                    <p class="mt-3">Este usuario no tiene pedidos</p>
                </div>
            }
        </div>
    </div>

    <!-- Columna Derecha -->
    <div class="col-12 col-lg-4">
        <!-- Estado del Usuario -->
        <div class="stat-card mb-3">
            <h6 class="mb-3">
                <i class="bi bi-toggle-on me-2"></i>Estado del Usuario
            </h6>
            <div class="mb-3">
                @if (Model.Active)
                {
                    <span class="badge bg-success" style="font-size: 1rem; padding: 0.5rem 1rem;">
                        <i class="bi bi-check-circle"></i> Activo
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary" style="font-size: 1rem; padding: 0.5rem 1rem;">
                        <i class="bi bi-x-circle"></i> Inactivo
                    </span>
                }
            </div>

            <form asp-action="ToggleUserStatus" asp-route-userId="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-@(Model.Active ? "warning" : "success") w-100">
                    <i class="bi bi-@(Model.Active ? "eye-slash" : "eye")"></i>
                    @(Model.Active ? "Desactivar Usuario" : "Activar Usuario")
                </button>
            </form>

            @if (!Model.Active)
            {
                <div class="alert alert-warning mt-3 mb-0">
                    <small>
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Los usuarios inactivos no pueden iniciar sesión.
                    </small>
                </div>
            }
        </div>

        <!-- Gestión de Roles -->
        <div class="stat-card">
            <h6 class="mb-3">
                <i class="bi bi-shield me-2"></i>Gestión de Roles
            </h6>

            <div class="mb-3">
                <label class="text-muted mb-2">Rol Actual:</label>
                <div>
                    @foreach (var role in Model.CurrentRoles)
                    {
                        if (role == "Administrator")
                        {
                            <span class="badge bg-danger" style="font-size: 0.9rem; padding: 0.4rem 0.8rem;">
                                <i class="bi bi-shield-fill"></i> Administrador
                            </span>
                        }
                        else if (role == "Client")
                        {
                            <span class="badge bg-primary" style="font-size: 0.9rem; padding: 0.4rem 0.8rem;">
                                <i class="bi bi-person"></i> Cliente
                            </span>
                        }
                    }
                </div>
            </div>

            <form asp-action="ChangeUserRole" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Cambiar a:</label>
                    <select name="newRole" class="form-select">
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role.Value" selected="@Model.CurrentRoles.Contains(role.Value)">
                                @role.Text
                            </option>
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-admin-primary w-100">
                    <i class="bi bi-arrow-repeat"></i> Cambiar Rol
                </button>
            </form>

            <div class="alert alert-info mt-3 mb-0">
                <small>
                    <i class="bi bi-info-circle me-1"></i>
                    <strong>Administrador:</strong> Acceso total al panel admin.<br>
                    <strong>Cliente:</strong> Solo puede realizar compras.
                </small>
            </div>
        </div>
    </div>
</div>
