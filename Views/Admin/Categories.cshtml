@using DnTech_ECommerce.ViewModels
@model AdminCategoriesViewModel

@{
    ViewData["Title"] = "Gestión de Categorías";
    Layout = "_AdminLayout";
}

<!-- Encabezado con botón crear -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Gestión de Categorías</h4>
    <a asp-action="CreateCategory" class="btn btn-admin-primary">
        <i class="bi bi-plus-lg me-1"></i> Crear Categoría
    </a>
</div>

<!-- Alertas de TempData -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Estadísticas rápidas -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-success me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalActive</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Activas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-secondary me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalInactive</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Inactivas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-primary me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalWithProducts</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Con productos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-warning me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-inbox"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalEmpty</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Vacías</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="admin-filters mb-4">
    <form asp-action="Categories" method="get">
        <div class="row g-3">
            <!-- Búsqueda -->
            <div class="col-12 col-md-6">
                <label class="form-label">
                    <i class="bi bi-search me-1"></i>Buscar
                </label>
                <input type="text" class="form-control" name="SearchTerm" value="@Model.SearchTerm"
                       placeholder="Nombre o descripción...">
            </div>

            <!-- Estado -->
            <div class="col-6 col-md-3">
                <label class="form-label">
                    <i class="bi bi-funnel me-1"></i>Estado
                </label>
                <select class="form-select" name="FilterIsActive">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.FilterIsActive == true)">Activas</option>
                    <option value="false" selected="@(Model.FilterIsActive == false)">Inactivas</option>
                </select>
            </div>

            <!-- Botones -->
            <div class="col-6 col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-admin-primary w-100 me-2">
                    <i class="bi bi-search"></i> Filtrar
                </button>
                <a asp-action="Categories" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- Tabla de categorías -->
<div class="admin-table">
    <div class="p-3 border-bottom">
        <h5 class="mb-0">
            <i class="bi bi-tags me-2"></i>
            Categorías (@Model.TotalCategories)
        </h5>
    </div>

    @if (Model.Categories.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Imagen</th>
                        <th>Categoría</th>
                        <th>Slug</th>
                        <th>Descripción</th>
                        <th>Productos</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr class="@(!category.IsActive ? "table-secondary" : "")">
                            <td>
                                @if (!string.IsNullOrEmpty(category.ImageUrl))
                                {
                                    <img src="@category.ImageUrl" alt="@category.Name"
                                         style="width: 60px; height: 60px; object-fit: cover; border-radius: 0.375rem;">
                                }
                                else
                                {
                                    <div style="width: 60px; height: 60px; background-color: #e9ecef; border-radius: 0.375rem; display: flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-tag text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div><strong>@category.Name</strong></div>
                                <small class="text-muted">ID: @category.Id</small>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(category.Slug))
                                {
                                    <code>@category.Slug</code>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(category.Description))
                                {
                                    <span class="text-muted" style="font-size: 0.875rem;">
                                        @(category.Description.Length > 60 ? category.Description.Substring(0, 60) + "..." : category.Description)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (category.ProductCount == 0)
                                {
                                    <span class="badge bg-warning text-dark">Sin productos</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">@category.ProductCount</span>
                                }
                            </td>
                            <td>
                                @if (category.IsActive)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="EditCategory" asp-route-id="@category.Id"
                                       class="btn btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="ToggleCategoryStatus" asp-route-id="@category.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-@(category.IsActive ? "warning" : "success")"
                                                title="@(category.IsActive ? "Desactivar" : "Activar")">
                                            <i class="bi bi-@(category.IsActive ? "eye-slash" : "eye")"></i>
                                        </button>
                                    </form>

                                    @if (category.IsActive)
                                    {
                                        <button type="button" class="btn btn-outline-danger" title="Eliminar"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal@(category.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>

                                <!-- Modal de confirmación de eliminación -->
                                <div class="modal fade" id="deleteModal@(category.Id)" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Confirmar Eliminación</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>¿Estás seguro de que deseas eliminar (desactivar) la categoría?</p>
                                                <p><strong>@category.Name</strong></p>
                                                @if (category.ProductCount > 0)
                                                {
                                                    <div class="alert alert-warning">
                                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                                        Esta categoría tiene <strong>@category.ProductCount producto(s) activo(s)</strong>.
                                                        No podrá eliminarse hasta que se reasignen o desactiven.
                                                    </div>
                                                }
                                                else
                                                {
                                                    <p class="text-muted">La categoría será desactivada y no será visible en la tienda.</p>
                                                }
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                @if (category.ProductCount == 0)
                                                {
                                                    <form asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger">Eliminar</button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (Model.TotalPages > 1)
        {
            <div class="p-3 border-top">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Categories"
                               asp-route-currentPage="@(Model.CurrentPage - 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-filterIsActive="@Model.FilterIsActive">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Categories"
                                   asp-route-currentPage="@i"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-filterIsActive="@Model.FilterIsActive">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Categories"
                               asp-route-currentPage="@(Model.CurrentPage + 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-filterIsActive="@Model.FilterIsActive">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
                <div class="text-center mt-2 text-muted">
                    <small>Página @Model.CurrentPage de @Model.TotalPages - Total: @Model.TotalCategories categorías</small>
                </div>
            </div>
        }
    }
    else
    {
        <div class="p-5 text-center text-muted">
            <i class="bi bi-inbox display-3"></i>
            <p class="mt-3">No se encontraron categorías</p>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.FilterIsActive.HasValue)
            {
                <a asp-action="Categories" class="btn btn-outline-primary mt-2">
                    <i class="bi bi-arrow-clockwise me-1"></i>Limpiar filtros
                </a>
            }
        </div>
    }
</div>

