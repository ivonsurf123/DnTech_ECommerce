@model DnTech_Ecommerce.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Crear Producto";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-12 col-lg-8 mx-auto">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Crear Nuevo Producto
                </h4>
                <a asp-action="Products" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

            <form asp-action="CreateProduct" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Información Básica -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-info-circle me-2"></i>Información Básica
                </h5>

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
                            <option value="">-- Selecciona una categoría --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Sku" class="form-label"></label>
                        <input asp-for="Sku" class="form-control" placeholder="Ej: PROD-001" />
                        <span asp-validation-for="Sku" class="text-danger"></span>
                    </div>
                </div>

                <!-- Precios e Inventario -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-currency-dollar me-2"></i>Precios e Inventario
                </h5>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">₡</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="OldPrice" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">₡</span>
                            <input asp-for="OldPrice" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="OldPrice" class="text-danger"></span>
                        <small class="text-muted">Precio anterior para mostrar descuento</small>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StockQuantity" class="form-label"></label>
                        <input asp-for="StockQuantity" class="form-control" type="number" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>
                </div>

                <!-- Imagen -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-image me-2"></i>Imagen del Producto
                </h5>

                <div class="mb-4">
                    <label asp-for="MainImage" class="form-label"></label>
                    <input asp-for="MainImage" class="form-control" type="file" accept="image/*" id="imageInput" />
                    <span asp-validation-for="MainImage" class="text-danger"></span>
                    <small class="text-muted d-block mt-1">Formatos: JPG, PNG. Tamaño máximo: 2MB</small>

                    <!-- Vista previa de imagen -->
                    <div id="imagePreview" class="mt-3" style="display: none;">
                        <p class="mb-2"><strong>Vista previa:</strong></p>
                        <img id="previewImg" src="" alt="Preview" style="max-width: 200px; border-radius: 0.375rem; border: 1px solid #dee2e6;">
                    </div>
                </div>

                <!-- Opciones -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-toggles me-2"></i>Opciones
                </h5>

                <div class="row g-3 mb-4">
                    <div class="col-md-3 col-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-3 col-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                            <label asp-for="IsFeatured" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-3 col-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsNew" class="form-check-input" type="checkbox" />
                            <label asp-for="IsNew" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-3 col-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsOnSale" class="form-check-input" type="checkbox" />
                            <label asp-for="IsOnSale" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <!-- Botones -->
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Products" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                    <button type="submit" class="btn btn-admin-primary">
                        <i class="bi bi-check-lg me-1"></i>Crear Producto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Vista previa de imagen
        document.getElementById('imageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}
