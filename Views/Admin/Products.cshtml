@using DnTech_ECommerce.ViewModels
@model AdminProductsViewModel

@{
    ViewData["Title"] = "Gestión de Productos";
    Layout = "_AdminLayout";
}

<!-- Encabezado con botón crear -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Gestión de Productos</h4>
    <a asp-action="CreateProduct" class="btn btn-admin-primary">
        <i class="bi bi-plus-lg me-1"></i> Crear Producto
    </a>
</div>

<!-- Estadísticas rápidas -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-success me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalActive</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Activos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-secondary me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalInactive</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Inactivos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-danger me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalOutOfStock</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Sin Stock</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-warning me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-info-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalLowStock</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Stock Bajo</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="admin-filters mb-4">
    <form asp-action="Products" method="get">
        <div class="row g-3">
            <!-- Búsqueda -->
            <div class="col-12 col-md-4">
                <label class="form-label">
                    <i class="bi bi-search me-1"></i>Buscar
                </label>
                <input type="text" class="form-control" name="SearchTerm" value="@Model.SearchTerm"
                       placeholder="Nombre, descripción o SKU...">
            </div>

            <!-- Categoría -->
            <div class="col-6 col-md-3">
                <label class="form-label">
                    <i class="bi bi-tag me-1"></i>Categoría
                </label>
                <select class="form-select" name="FilterCategoryId">
                    <option value="">Todas</option>
                    @if (Model.Categories != null)
                    {
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Value" selected="@(Model.FilterCategoryId?.ToString() == category.Value)">
                                @category.Text
                            </option>
                        }
                    }
                </select>
            </div>

            <!-- Estado -->
            <div class="col-6 col-md-2">
                <label class="form-label">
                    <i class="bi bi-funnel me-1"></i>Estado
                </label>
                <select class="form-select" name="FilterIsActive">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.FilterIsActive == true)">Activos</option>
                    <option value="false" selected="@(Model.FilterIsActive == false)">Inactivos</option>
                </select>
            </div>

            <!-- Botones -->
            <div class="col-12 col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-admin-primary w-100 me-2">
                    <i class="bi bi-search"></i> Filtrar
                </button>
                <a asp-action="Products" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>
        </div>

        <!-- Filtros rápidos (chips) -->
        <div class="mt-3">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="FilterLowStock" id="filterLowStock"
                       value="true" checked="@(Model.FilterLowStock == true)">
                <label class="form-check-label" for="filterLowStock">Stock Bajo</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="FilterOutOfStock" id="filterOutOfStock"
                       value="true" checked="@(Model.FilterOutOfStock == true)">
                <label class="form-check-label" for="filterOutOfStock">Sin Stock</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="FilterIsFeatured" id="filterFeatured"
                       value="true" checked="@(Model.FilterIsFeatured == true)">
                <label class="form-check-label" for="filterFeatured">Destacados</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="FilterIsOnSale" id="filterOnSale"
                       value="true" checked="@(Model.FilterIsOnSale == true)">
                <label class="form-check-label" for="filterOnSale">En Oferta</label>
            </div>
        </div>
    </form>
</div>

<!-- Tabla de productos -->
<div class="admin-table">
    <div class="p-3 border-bottom">
        <h5 class="mb-0">
            <i class="bi bi-grid me-2"></i>
            Productos (@Model.TotalProducts)
        </h5>
    </div>

    @if (Model.Products.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Imagen</th>
                        <th>Producto</th>
                        <th>SKU</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th>Etiquetas</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr class="@(!product.IsActive ? "table-secondary" : "")">
                            <td>
                                @if (!string.IsNullOrEmpty(product.MainImageUrl))
                                {
                                    <img src="@product.MainImageUrl" alt="@product.Name"
                                         style="width: 60px; height: 60px; object-fit: cover; border-radius: 0.375rem;">
                                }
                                else
                                {
                                    <div style="width: 60px; height: 60px; background-color: #e9ecef; border-radius: 0.375rem; display: flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div><strong>@product.Name</strong></div>
                                <small class="text-muted">ID: @product.Id</small>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(product.Sku))
                                {
                                    <code>@product.Sku</code>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">@product.CategoryName</span>
                            </td>
                            <td>
                                <div><strong>@product.Price.ToString("C")</strong></div>
                                @if (product.OldPrice.HasValue && product.OldPrice > product.Price)
                                {
                                    <small class="text-muted text-decoration-line-through">
                                        @product.OldPrice.Value.ToString("C")
                                    </small>
                                }
                            </td>
                            <td>
                                @if (product.StockQuantity == 0)
                                {
                                    <span class="badge bg-danger">Sin stock</span>
                                }
                                else if (product.StockQuantity < 10)
                                {
                                    <span class="badge bg-warning text-dark">@product.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@product.StockQuantity</span>
                                }
                            </td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    @if (product.IsFeatured)
                                    {
                                        <span class="badge bg-primary" style="font-size: 0.75rem;">
                                            <i class="bi bi-star-fill"></i>
                                        </span>
                                    }
                                    @if (product.IsNew)
                                    {
                                        <span class="badge bg-info" style="font-size: 0.75rem;">
                                            <i class="bi bi-sparkles"></i>
                                        </span>
                                    }
                                    @if (product.IsOnSale)
                                    {
                                        <span class="badge bg-danger" style="font-size: 0.75rem;">
                                            <i class="bi bi-percent"></i>
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="EditProduct" asp-route-id="@product.Id"
                                       class="btn btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form asp-action="ToggleProductStatus" asp-route-id="@product.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-outline-@(product.IsActive ? "warning" : "success")"
                                                title="@(product.IsActive ? "Desactivar" : "Activar")">
                                            <i class="bi bi-@(product.IsActive ? "eye-slash" : "eye")"></i>
                                        </button>
                                    </form>

                                    @if (product.IsActive)
                                    {
                                        <button type="button" class="btn btn-outline-danger" title="Eliminar"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal@(product.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>

                                <!-- Modal de confirmación de eliminación -->
                                <div class="modal fade" id="deleteModal@(product.Id)" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Confirmar Eliminación</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>¿Estás seguro de que deseas eliminar (desactivar) el producto?</p>
                                                <p><strong>@product.Name</strong></p>
                                                <p class="text-muted">El producto será desactivado y no será visible en la tienda.</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                <form asp-action="DeleteProduct" asp-route-id="@product.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger">Eliminar</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (Model.TotalPages > 1)
        {
            <div class="p-3 border-top">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Products"
                               asp-route-currentPage="@(Model.CurrentPage - 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-filterCategoryId="@Model.FilterCategoryId"
                               asp-route-filterIsActive="@Model.FilterIsActive">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Products"
                                   asp-route-currentPage="@i"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-filterCategoryId="@Model.FilterCategoryId"
                                   asp-route-filterIsActive="@Model.FilterIsActive">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Products"
                               asp-route-currentPage="@(Model.CurrentPage + 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-filterCategoryId="@Model.FilterCategoryId"
                               asp-route-filterIsActive="@Model.FilterIsActive">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
                <div class="text-center mt-2 text-muted">
                    <small>Página @Model.CurrentPage de @Model.TotalPages - Total: @Model.TotalProducts productos</small>
                </div>
            </div>
        }
    }
    else
    {
        <div class="p-5 text-center text-muted">
            <i class="bi bi-inbox display-3"></i>
            <p class="mt-3">No se encontraron productos</p>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.FilterCategoryId.HasValue)
            {
                <a asp-action="Products" class="btn btn-outline-primary mt-2">
                    <i class="bi bi-arrow-clockwise me-1"></i>Limpiar filtros
                </a>
            }
        </div>
    }
</div>