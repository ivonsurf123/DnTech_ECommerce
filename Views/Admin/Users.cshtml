@using DnTech_ECommerce.ViewModels
@model AdminUsersViewModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "_AdminLayout";
}

<!-- Estadísticas rápidas -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-primary me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalAdministrators</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Administradores</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-info me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalClients</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Clientes</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-success me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalActive</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Activos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="d-flex align-items-center">
                <div class="stat-icon bg-secondary me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalInactive</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Inactivos</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="admin-filters mb-4">
    <form asp-action="Users" method="get">
        <div class="row g-3">
            <!-- Búsqueda -->
            <div class="col-12 col-md-5">
                <label class="form-label">
                    <i class="bi bi-search me-1"></i>Buscar
                </label>
                <input type="text" class="form-control" name="SearchTerm" value="@Model.SearchTerm"
                       placeholder="Nombre o email...">
            </div>

            <!-- Rol -->
            <div class="col-6 col-md-2">
                <label class="form-label">
                    <i class="bi bi-funnel me-1"></i>Rol
                </label>
                <select class="form-select" name="FilterRole">
                    <option value="">Todos</option>
                    <option value="Administrator" selected="@(Model.FilterRole == "Administrator")">Administrador</option>
                    <option value="Client" selected="@(Model.FilterRole == "Client")">Cliente</option>
                </select>
            </div>

            <!-- Estado -->
            <div class="col-6 col-md-2">
                <label class="form-label">
                    <i class="bi bi-toggle-on me-1"></i>Estado
                </label>
                <select class="form-select" name="FilterIsActive">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.FilterIsActive == true)">Activos</option>
                    <option value="false" selected="@(Model.FilterIsActive == false)">Inactivos</option>
                </select>
            </div>

            <!-- Botones -->
            <div class="col-12 col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-admin-primary w-100 me-2">
                    <i class="bi bi-search"></i> Filtrar
                </button>
                <a asp-action="Users" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- Tabla de usuarios -->
<div class="admin-table">
    <div class="p-3 border-bottom">
        <h5 class="mb-0">
            <i class="bi bi-people me-2"></i>
            Usuarios (@Model.TotalUsers)
        </h5>
    </div>

    @if (Model.Users.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Ciudad</th>
                        <th>Rol</th>
                        <th>Pedidos</th>
                        <th>Estado</th>
                        <th>Fecha Registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr class="@(!user.Active ? "table-secondary" : "")">
                            <td>
                                <div><strong>@user.FullName</strong></div>
                                <small class="text-muted">ID: @user.Id.Substring(0, 8)</small>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                {
                                    <span>@user.PhoneNumber</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.City))
                                {
                                    <span>@user.City</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    if (role == "Administrator")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-shield-fill"></i> Admin
                                        </span>
                                    }
                                    else if (role == "Client")
                                    {
                                        <span class="badge bg-primary">
                                            <i class="bi bi-person"></i> Cliente
                                        </span>
                                    }
                                }
                            </td>
                            <td>
                                @if (user.TotalOrders > 0)
                                {
                                    <span class="badge bg-info">@user.TotalOrders</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">0</span>
                                }
                            </td>
                            <td>
                                @if (user.Active)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div>@user.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <small class="text-muted">@user.CreatedAt.ToString("HH:mm")</small>
                            </td>
                            <td>
                                <a asp-action="UserDetails" asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-primary" title="Ver Detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (Model.TotalPages > 1)
        {
            <div class="p-3 border-top">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Users"
                               asp-route-currentPage="@(Model.CurrentPage - 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-filterRole="@Model.FilterRole"
                               asp-route-filterIsActive="@Model.FilterIsActive">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Users"
                                   asp-route-currentPage="@i"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-filterRole="@Model.FilterRole"
                                   asp-route-filterIsActive="@Model.FilterIsActive">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Users"
                               asp-route-currentPage="@(Model.CurrentPage + 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-filterRole="@Model.FilterRole"
                               asp-route-filterIsActive="@Model.FilterIsActive">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
                <div class="text-center mt-2 text-muted">
                    <small>Página @Model.CurrentPage de @Model.TotalPages - Total: @Model.TotalUsers usuarios</small>
                </div>
            </div>
        }
    }
    else
    {
        <div class="p-5 text-center text-muted">
            <i class="bi bi-inbox display-3"></i>
            <p class="mt-3">No se encontraron usuarios</p>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.FilterRole))
            {
                <a asp-action="Users" class="btn btn-outline-primary mt-2">
                    <i class="bi bi-arrow-clockwise me-1"></i>Limpiar filtros
                </a>
            }
        </div>
    }
</div>
