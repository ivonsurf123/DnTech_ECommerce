@using DnTech_ECommerce.ViewModels
@model CategoryViewModel

@{
    ViewData["Title"] = $"Editar Categoría: {Model.Name}";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-12 col-lg-7 mx-auto">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Editar Categoría
                </h4>
                <a asp-action="Categories" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

            <form asp-action="EditCategory" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Información Básica -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-info-circle me-2"></i>Información Básica
                </h5>

                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <!-- Imagen -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-image me-2"></i>Imagen de la Categoría
                </h5>

                <div class="mb-4">
                    <!-- Imagen actual -->
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3">
                            <p class="mb-2"><strong>Imagen actual:</strong></p>
                            <img src="@Model.ImageUrl" alt="@Model.Name"
                                 style="max-width: 150px; border-radius: 0.375rem; border: 1px solid #dee2e6;">
                        </div>
                    }

                    <label asp-for="Image" class="form-label">
                        @(string.IsNullOrEmpty(Model.ImageUrl) ? "Imagen" : "Cambiar imagen")
                    </label>
                    <input asp-for="Image" class="form-control" type="file" accept="image/*" id="imageInput" />
                    <span asp-validation-for="Image" class="text-danger"></span>
                    <small class="text-muted d-block mt-1">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <span>Selecciona una nueva imagen para reemplazar la actual. Formatos: JPG, PNG. Máx: 2MB</span>
                        }
                        else
                        {
                            <span>Formatos: JPG, PNG. Tamaño máximo: 2MB</span>
                        }
                    </small>

                    <!-- Vista previa nueva imagen -->
                    <div id="imagePreview" class="mt-3" style="display: none;">
                        <p class="mb-2"><strong>Nueva imagen:</strong></p>
                        <img id="previewImg" src="" alt="Preview"
                             style="max-width: 200px; border-radius: 0.375rem; border: 1px solid #dee2e6;">
                    </div>
                </div>

                <!-- Opciones -->
                <h5 class="mb-3 pb-2 border-bottom">
                    <i class="bi bi-toggles me-2"></i>Opciones
                </h5>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>

                <!-- Botones -->
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Categories" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                    <button type="submit" class="btn btn-admin-primary">
                        <i class="bi bi-check-lg me-1"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('imageInput').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}

