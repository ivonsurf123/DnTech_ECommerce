@using DnTech_ECommerce.Models.Enums
@using DnTech_ECommerce.ViewModels
@model SalesReportViewModel
@{
    ViewData["Title"] = "Reporte de Ventas";
    Layout = "_AdminLayout";
    var filter = ViewBag.Filter as ReportFilterViewModel;
}

<!-- Header con botones de exportación -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Reporte de Ventas</h4>
        <small class="text-muted">
            <i class="bi bi-calendar"></i> @Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")
        </small>
    </div>
    <div class="btn-group">
        <a asp-action="ExportSalesExcel"
           asp-route-startDate="@Model.StartDate"
           asp-route-endDate="@Model.EndDate"
           class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <a asp-action="ExportSalesPDF"
           asp-route-startDate="@Model.StartDate"
           asp-route-endDate="@Model.EndDate"
           class="btn btn-danger">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<!-- Cards de resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="bi bi-cart-check"></i>
            </div>
            <div class="stat-value">@Model.TotalOrders</div>
            <div class="stat-label">Total Pedidos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <div class="stat-value">@Model.TotalRevenue.ToString("C")</div>
            <div class="stat-label">Ingresos Totales</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="bi bi-graph-up"></i>
            </div>
            <div class="stat-value">@Model.AverageOrderValue.ToString("C")</div>
            <div class="stat-label">Valor Promedio</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="bi bi-box-seam"></i>
            </div>
            <div class="stat-value">@Model.TotalItemsSold</div>
            <div class="stat-label">Productos Vendidos</div>
        </div>
    </div>
</div>

<!-- Estados -->
<div class="stat-card mb-4">
    <h5 class="mb-3"><i class="bi bi-pie-chart me-2"></i>Pedidos por Estado</h5>
    <div class="row text-center">
        <div class="col">
            <div class="stat-value text-warning">@Model.PendingOrders</div>
            <div class="stat-label">Pendientes</div>
        </div>
        <div class="col">
            <div class="stat-value text-info">@Model.ProcessingOrders</div>
            <div class="stat-label">Procesando</div>
        </div>
        <div class="col">
            <div class="stat-value text-primary">@Model.ShippedOrders</div>
            <div class="stat-label">Enviados</div>
        </div>
        <div class="col">
            <div class="stat-value text-success">@Model.DeliveredOrders</div>
            <div class="stat-label">Entregados</div>
        </div>
        <div class="col">
            <div class="stat-value text-danger">@Model.CancelledOrders</div>
            <div class="stat-label">Cancelados</div>
        </div>
    </div>
</div>

<!-- Tabla de pedidos -->
<div class="admin-table">
    <div class="p-3 border-bottom">
        <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Detalle de Pedidos</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Número</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Pago</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td><strong>@order.OrderNumber</strong></td>
                        <td>
                            <div>@order.OrderDate.ToString("dd/MM/yyyy")</div>
                            <small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                        </td>
                        <td>
                            <div>@order.CustomerName</div>
                            <small class="text-muted">@order.CustomerEmail</small>
                        </td>
                        <td><span class="badge bg-secondary">@order.ItemCount</span></td>
                        <td><strong>@order.TotalAmount.ToString("C")</strong></td>
                        <td>@order.PaymentMethod</td>
                        <td>
                            @switch (order.Status)
                            {
                                case OrderStatus.Pending:
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                    break;
                                case OrderStatus.Processing:
                                    <span class="badge bg-info">Procesando</span>
                                    break;
                                case OrderStatus.Shipped:
                                    <span class="badge bg-primary">Enviado</span>
                                    break;
                                case OrderStatus.Delivered:
                                    <span class="badge bg-success">Entregado</span>
                                    break;
                                case OrderStatus.Cancelled:
                                    <span class="badge bg-danger">Cancelado</span>
                                    break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>