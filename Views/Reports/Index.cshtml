@{
    ViewData["Title"] = "Reportes";
    Layout = "_AdminLayout";
}

<div class="row g-4">
    <!-- Reporte de Ventas -->
    <div class="col-12 col-md-6">
        <div class="stat-card h-100">
            <div class="d-flex align-items-start mb-3">
                <div class="stat-icon bg-success me-3" style="width: 60px; height: 60px; font-size: 1.8rem;">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <div class="flex-grow-1">
                    <h5 class="mb-2">Reporte de Ventas</h5>
                    <p class="text-muted mb-0">
                        Análisis detallado de ventas por período, incluyendo ingresos totales,
                        pedidos por estado y valor promedio.
                    </p>
                </div>
            </div>

            <div class="d-grid gap-2">
                <a asp-action="SalesReport" asp-route-period="today" class="btn btn-outline-primary">
                    <i class="bi bi-calendar-day me-1"></i> Hoy
                </a>
                <a asp-action="SalesReport" asp-route-period="week" class="btn btn-outline-primary">
                    <i class="bi bi-calendar-week me-1"></i> Esta Semana
                </a>
                <a asp-action="SalesReport" asp-route-period="month" class="btn btn-outline-primary">
                    <i class="bi bi-calendar-month me-1"></i> Este Mes
                </a>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#salesCustomModal">
                    <i class="bi bi-calendar-range me-1"></i> Período Personalizado
                </button>
            </div>
        </div>
    </div>

    <!-- Reporte de Productos -->
    <div class="col-12 col-md-6">
        <div class="stat-card h-100">
            <div class="d-flex align-items-start mb-3">
                <div class="stat-icon bg-info me-3" style="width: 60px; height: 60px; font-size: 1.8rem;">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div class="flex-grow-1">
                    <h5 class="mb-2">Reporte de Productos</h5>
                    <p class="text-muted mb-0">
                        Productos más vendidos, ingresos por producto,
                        y estado actual del inventario.
                    </p>
                </div>
            </div>

            <div class="d-grid gap-2">
                <a asp-action="ProductReport" asp-route-period="today" class="btn btn-outline-info">
                    <i class="bi bi-calendar-day me-1"></i> Hoy
                </a>
                <a asp-action="ProductReport" asp-route-period="week" class="btn btn-outline-info">
                    <i class="bi bi-calendar-week me-1"></i> Esta Semana
                </a>
                <a asp-action="ProductReport" asp-route-period="month" class="btn btn-outline-info">
                    <i class="bi bi-calendar-month me-1"></i> Este Mes
                </a>
                <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#productCustomModal">
                    <i class="bi bi-calendar-range me-1"></i> Período Personalizado
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Información adicional -->
<div class="row mt-4">
    <div class="col-12">
        <div class="stat-card">
            <h5 class="mb-3">
                <i class="bi bi-info-circle me-2"></i>Información sobre Reportes
            </h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <h6><i class="bi bi-file-earmark-excel text-success me-2"></i>Exportación a Excel</h6>
                    <p class="text-muted mb-0">
                        Descarga reportes en formato Excel (.xlsx) con todos los datos detallados
                        y formatos profesionales. Ideal para análisis adicional.
                    </p>
                </div>
                <div class="col-md-6 mb-3">
                    <h6><i class="bi bi-file-earmark-pdf text-danger me-2"></i>Exportación a PDF</h6>
                    <p class="text-muted mb-0">
                        Genera reportes en PDF listos para imprimir o compartir.
                        Incluyen resúmenes visuales y tablas organizadas.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Período Personalizado - Ventas -->
<div class="modal fade" id="salesCustomModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SalesReport" method="get">
                <div class="modal-header">
                    <h5 class="modal-title">Reporte de Ventas - Período Personalizado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Fecha Desde</label>
                        <input type="date" class="form-control" name="StartDate" required
                               value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha Hasta</label>
                        <input type="date" class="form-control" name="EndDate" required
                               value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Generar Reporte</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Período Personalizado - Productos -->
<div class="modal fade" id="productCustomModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ProductReport" method="get">
                <div class="modal-header">
                    <h5 class="modal-title">Reporte de Productos - Período Personalizado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Fecha Desde</label>
                        <input type="date" class="form-control" name="StartDate" required
                               value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha Hasta</label>
                        <input type="date" class="form-control" name="EndDate" required
                               value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-info">Generar Reporte</button>
                </div>
            </form>
        </div>
    </div>
</div>